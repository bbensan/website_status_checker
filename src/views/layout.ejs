<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' && title ? title + ' | ' : '' %>Status Monitor</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --bg-base: #0f172a;
            --bg-surface: #1e293b;
            --bg-elevated: #334155;
            --bg-hover: #3f5070;
            --border: #334155;
            --border-subtle: #253347;
            --text-primary: #f1f5f9;
            --text-secondary: #94a3b8;
            --text-muted: #64748b;
            --accent: #6366f1;
            --accent-hover: #818cf8;
            --accent-subtle: rgba(99,102,241,0.12);
            --success-bg: rgba(34,197,94,0.12);
            --success-text: #4ade80;
            --success-border: rgba(34,197,94,0.3);
            --danger-bg: rgba(239,68,68,0.12);
            --danger-text: #f87171;
            --danger-border: rgba(239,68,68,0.3);
            --warning-bg: rgba(234,179,8,0.12);
            --warning-text: #fbbf24;
            --warning-border: rgba(234,179,8,0.3);
            --info-bg: rgba(59,130,246,0.12);
            --info-text: #60a5fa;
            --info-border: rgba(59,130,246,0.3);
            --chart-up: #22c55e;
            --chart-down: #ef4444;
            --chart-line: #818cf8;
            --chart-fill: rgba(99,102,241,0.1);
        }

        html.light {
            --bg-base: #f1f5f9;
            --bg-surface: #ffffff;
            --bg-elevated: #f8fafc;
            --bg-hover: #e2e8f0;
            --border: #e2e8f0;
            --border-subtle: #f1f5f9;
            --text-primary: #0f172a;
            --text-secondary: #475569;
            --text-muted: #94a3b8;
            --accent: #4f46e5;
            --accent-hover: #4338ca;
            --accent-subtle: rgba(79,70,229,0.08);
            --success-bg: rgba(22,163,74,0.08);
            --success-text: #15803d;
            --success-border: rgba(22,163,74,0.2);
            --danger-bg: rgba(220,38,38,0.08);
            --danger-text: #b91c1c;
            --danger-border: rgba(220,38,38,0.2);
            --warning-bg: rgba(202,138,4,0.08);
            --warning-text: #92400e;
            --warning-border: rgba(202,138,4,0.2);
            --info-bg: rgba(37,99,235,0.08);
            --info-text: #1d4ed8;
            --info-border: rgba(37,99,235,0.2);
            --chart-line: #6366f1;
            --chart-fill: rgba(99,102,241,0.1);
        }

        body {
            background-color: var(--bg-base);
            color: var(--text-primary);
            transition: background-color 0.2s, color 0.2s;
        }

        nav { background-color: var(--bg-surface) !important; border-color: var(--border) !important; }
        footer { background-color: var(--bg-surface) !important; border-color: var(--border) !important; }

        .card {
            background-color: var(--bg-surface);
            border-color: var(--border);
            transition: background-color 0.2s, border-color 0.2s;
        }
        .card:hover { background-color: var(--bg-elevated); }

        .card-elevated {
            background-color: var(--bg-elevated);
            border-color: var(--border);
        }

        .text-primary { color: var(--text-primary); }
        .text-secondary { color: var(--text-secondary); }
        .text-muted { color: var(--text-muted); }
        .border-theme { border-color: var(--border); }
        .border-subtle { border-color: var(--border-subtle); }
        .bg-surface { background-color: var(--bg-surface); }
        .bg-elevated { background-color: var(--bg-elevated); }
        .bg-hover:hover { background-color: var(--bg-hover); }

        .accent { color: var(--accent); }
        .accent-hover:hover { color: var(--accent-hover); }
        .accent-bg { background-color: var(--accent); }
        .accent-bg:hover { background-color: var(--accent-hover); }
        .accent-subtle { background-color: var(--accent-subtle); }

        .btn-primary {
            background-color: var(--accent);
            color: #fff;
        }
        .btn-primary:hover { background-color: var(--accent-hover); }

        .btn-outline {
            background-color: transparent;
            border-color: var(--border);
            color: var(--text-secondary);
        }
        .btn-outline:hover { background-color: var(--bg-hover); color: var(--text-primary); }

        .input-field {
            background-color: var(--bg-base);
            border-color: var(--border);
            color: var(--text-primary);
        }
        .input-field:focus { border-color: var(--accent); outline: none; box-shadow: 0 0 0 2px var(--accent-subtle); }
        .input-field::placeholder { color: var(--text-muted); }

        .table-container { background-color: var(--bg-surface); border-color: var(--border); }
        .table-wrapper { overflow-x: auto; }
        .table-header { background-color: var(--bg-elevated); border-color: var(--border-subtle); }
        .table-header th { color: var(--text-muted); }
        .table-body tr { border-color: var(--border-subtle); }
        .table-body tr:hover { background-color: var(--bg-elevated); }
        .table-body td { color: var(--text-secondary); }

        .badge-up { background-color: var(--success-bg); color: var(--success-text); border: 1px solid var(--success-border); }
        .badge-down { background-color: var(--danger-bg); color: var(--danger-text); border: 1px solid var(--danger-border); }
        .badge-na { background-color: var(--bg-elevated); color: var(--text-muted); border: 1px solid var(--border); }

        .badge-2xx { background-color: var(--success-bg); color: var(--success-text); border: 1px solid var(--success-border); }
        .badge-3xx { background-color: var(--info-bg); color: var(--info-text); border: 1px solid var(--info-border); }
        .badge-4xx { background-color: var(--warning-bg); color: var(--warning-text); border: 1px solid var(--warning-border); }
        .badge-5xx { background-color: var(--danger-bg); color: var(--danger-text); border: 1px solid var(--danger-border); }

        .stat-bar-bg { background-color: var(--bg-elevated); }

        .error-msg { color: var(--danger-text); }
        .success-text { color: var(--success-text); }
        .warning-text { color: var(--warning-text); }

        .animate-spin { animation: spin 1s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }

        [x-cloak] { display: none !important; }
    </style>
</head>
<body>
    <nav class="border-b border-theme">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between h-16 items-center">
                <div class="flex items-center gap-6">
                    <a href="/" class="text-lg font-semibold text-primary accent-hover transition">Dashboard</a>
                    <a href="/config" class="text-lg font-medium text-secondary accent-hover transition">Configuration</a>
                </div>
                <button id="theme-toggle" onclick="toggleTheme()" title="Toggle theme"
                    class="p-2 rounded-lg border border-theme text-secondary hover:text-primary hover:bg-hover transition">
                    <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
                    </svg>
                    <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
                    </svg>
                </button>
            </div>
        </div>
    </nav>

    <main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-8 mb-16">
        <%- body %>
    </main>

    <footer class="border-t border-theme fixed bottom-0 w-full">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
            <p class="text-center text-sm text-muted">Status Monitor &mdash; Simple website health checker</p>
        </div>
    </footer>

    <script>
        function toggleTheme() {
            const html = document.documentElement;
            const isDark = !html.classList.contains('light');
            if (isDark) {
                html.classList.add('light');
                localStorage.setItem('theme', 'light');
                document.getElementById('icon-moon').classList.add('hidden');
                document.getElementById('icon-sun').classList.remove('hidden');
            } else {
                html.classList.remove('light');
                localStorage.setItem('theme', 'dark');
                document.getElementById('icon-moon').classList.remove('hidden');
                document.getElementById('icon-sun').classList.add('hidden');
            }
            // Re-render charts if any exist
            window.dispatchEvent(new Event('theme-changed'));
        }

        (function() {
            const saved = localStorage.getItem('theme');
            if (saved === 'light') {
                document.documentElement.classList.add('light');
                document.getElementById('icon-moon').classList.add('hidden');
                document.getElementById('icon-sun').classList.remove('hidden');
            }
        })();
    </script>
</body>
</html>
